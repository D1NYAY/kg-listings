# ===========================================
# KG Listings - Переменные окружения
# ===========================================
# Скопируй в .env и заполни значения

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/kg_listings"

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"
# Админы: telegram ID через запятую (используется для модерации и /admindelete)
TELEGRAM_ADMIN_IDS="123456789,987654321"
ADMIN_TELEGRAM_IDS="123456789,987654321"
TELEGRAM_CHANNEL_ID="@your_channel_username"
TELEGRAM_CHANNEL_CHAT_ID="-1001234567890"

# --- Backend API ---
API_PORT=3001
API_URL="http://localhost:3001"
NODE_ENV=development

# --- Mini App ---
MINI_APP_URL="https://your-domain.com"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_BOT_USERNAME="kg_listings_bot"
# Локально: MINI_APP_URL и NEXT_PUBLIC_* задаются в mini-app/.env.local
