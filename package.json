{
  "name": "kg-listings",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram объявления для Кыргызстана - MVP",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:bot\" \"npm run dev:mini-app\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:bot": "npm run dev --workspace=bot",
    "dev:mini-app": "npm run dev --workspace=mini-app",
    "build": "npm run build --workspace=backend && npm run build --workspace=mini-app && npm run build --workspace=bot",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "workspaces": [
    "backend",
    "bot",
    "mini-app"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tsx": "^4.19.2",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
